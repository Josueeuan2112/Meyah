# Variables de entorno del frontend (Vite expone solo las que empiezan con VITE_).
# Copia este archivo a .env.local y rellena los valores. NUNCA commitees .env.local.

# Supabase (requeridas)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Sentry (opcional): si se define, activa el reporte de errores en producción.
# Déjala vacía o sin definir para desactivar el monitoreo.
VITE_SENTRY_DSN=
